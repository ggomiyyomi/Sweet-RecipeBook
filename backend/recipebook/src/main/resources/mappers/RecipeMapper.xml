<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sweetrecipe.recipebook.mapper.RecipeMapper">

    <!-- ===== ResultMaps ===== -->

    <resultMap id="IngredientResultMap"
               type="com.sweetrecipe.recipebook.dto.response.IngredientResponse">
        <id  property="ingredientId" column="ingredient_id"/>
        <result property="name"       column="name"/>
        <result property="amount"     column="amount"/>
        <result property="unit"       column="unit"/>
        <result property="sortOrder"  column="sort_order"/>
    </resultMap>

    <resultMap id="StepResultMap"
               type="com.sweetrecipe.recipebook.dto.response.RecipeStepResponse">
        <id  property="stepId"       column="step_id"/>
        <result property="stepType"  column="step_type"/>
        <result property="stepOrder" column="step_order"/>
        <result property="description" column="description"/>
        <result property="imageUrl"  column="image_url"/>
    </resultMap>

    <resultMap id="RecipeDetailResultMap"
               type="com.sweetrecipe.recipebook.dto.response.RecipeDetailResponse">
        <id  property="recipeId"      column="recipe_id"/>
        <result property="userId"     column="user_id"/>
        <result property="title"      column="title"/>
        <result property="thumbnailUrl" column="thumbnail_url"/>
        <result property="cookingTime"  column="cooking_time"/>
        <result property="review"     column="review"/>
        <result property="memo"       column="memo"/>
        <result property="createdAt"  column="created_at"/>
        <result property="updatedAt"  column="updated_at"/>
        <collection property="ingredients" column="recipe_id"
                    select="selectIngredientsByRecipeId"/>
        <collection property="steps" column="recipe_id"
                    select="selectStepsByRecipeId"/>
    </resultMap>

    <!-- ===== Queries ===== -->

    <select id="selectIngredientsByRecipeId" resultMap="IngredientResultMap">
        SELECT ingredient_id, name, amount, unit, sort_order
        FROM INGREDIENT
        WHERE recipe_id = #{recipeId}
        ORDER BY sort_order
    </select>

    <select id="selectStepsByRecipeId" resultMap="StepResultMap">
        SELECT step_id, step_type, step_order, description, image_url
        FROM RECIPE_STEP
        WHERE recipe_id = #{recipeId}
        ORDER BY step_type, step_order
    </select>

    <insert id="insertRecipe" parameterType="com.sweetrecipe.recipebook.dto.request.RecipeCreateRequest"
            useGeneratedKeys="true" keyProperty="recipeId">
        INSERT INTO RECIPE (user_id, title, thumbnail_url, cooking_time, review, memo)
        VALUES (#{userId}, #{title}, #{thumbnailUrl}, #{cookingTime}, #{review}, #{memo})
    </insert>

    <insert id="insertIngredients">
        INSERT INTO INGREDIENT (recipe_id, name, amount, unit, sort_order)
        VALUES
        <foreach collection="ingredients" item="i" separator=",">
            (#{recipeId}, #{i.name}, #{i.amount}, #{i.unit}, #{i.sortOrder})
        </foreach>
    </insert>

    <insert id="insertSteps">
        INSERT INTO RECIPE_STEP (recipe_id, step_type, step_order, description, image_url)
        VALUES
        <foreach collection="steps" item="s" separator=",">
            (#{recipeId}, #{s.stepType}, #{s.stepOrder}, #{s.description}, #{s.imageUrl})
        </foreach>
    </insert>

    <select id="findAllByUserId" resultType="com.sweetrecipe.recipebook.dto.response.RecipeSummaryResponse">
        SELECT recipe_id, title, thumbnail_url, cooking_time, created_at
        FROM RECIPE
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <select id="findDetailById" resultMap="RecipeDetailResultMap">
        SELECT recipe_id, user_id, title, thumbnail_url, cooking_time, review, memo, created_at, updated_at
        FROM RECIPE
        WHERE recipe_id = #{recipeId}
    </select>

</mapper>
